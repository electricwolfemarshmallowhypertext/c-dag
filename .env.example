# Optional local overrides for service entrypoints
MODEL_CONFIG_PATH=configs/credit_risk_model.v1.json
POLICY_CONFIG_PATH=configs/decision_policy.v1.json

# Auth mode
AUTH_MODE=none
# API_KEY=change-me

# Audit storage mode
AUDIT_STORE=none
AUDIT_STORE_PATH=outputs/audit_store/local_audit.db

# Tenancy mode
TENANCY_MODE=single

# Runtime controls
AUDIT_RETENTION_DAYS=365
LOG_LEVEL=info

# Optional API runtime defaults
API_HOST=127.0.0.1
API_PORT=8000
